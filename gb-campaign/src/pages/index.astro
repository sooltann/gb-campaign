---
import '../styles/global.css';
---

<html lang="ur" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>میجر فہد حنیف خان | آفیشل کیمپین</title>
  </head>
  <body class="bg-[#0A2F1D] text-white">

    <nav class="border-b border-[#C5A25D]/30 bg-[#062013] px-6 py-4 sticky top-0 z-50 relative">
      <div class="max-w-7xl mx-auto flex justify-between items-center">

        <div class="text-[#C5A25D] font-bold text-2xl md:text-3xl font-urdu">
          میجر فہد حنیف خان
        </div>

        <div class="hidden lg:flex space-x-8 space-x-reverse font-urdu text-lg">
          <a href="/" class="text-[#C5A25D] border-b-2 border-[#C5A25D] pb-1">مرکزی صفحہ</a>
          <a href="/meet-fahad" class="hover:text-[#C5A25D] transition text-gray-300">تعارف</a>
          <a href="/blueprint" class="hover:text-[#C5A25D] transition text-gray-300">منشور</a>
          <a href="/youth" class="hover:text-[#C5A25D] transition text-gray-300">نوجوانان</a>
          <a href="/media" class="hover:text-[#C5A25D] transition text-gray-300">میڈیا سینٹر</a>
        </div>

        <div class="hidden lg:block">
          <a href="/donate" class="bg-[#C5A25D] text-[#0A2F1D] px-6 py-2 rounded-md font-bold font-urdu text-lg hover:bg-white transition shadow-[0_0_15px_rgba(197,162,93,0.4)]">
            حصہ ڈالیں
          </a>
        </div>

        <button id="mobileMenuBtn" class="lg:hidden text-[#C5A25D] focus:outline-none hover:text-white transition">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <div id="mobileMenu" class="hidden lg:hidden absolute top-full left-0 w-full bg-[#062013] border-b border-[#C5A25D]/30 shadow-2xl font-urdu text-center py-6 space-y-6 z-40">
        <a href="/" class="block text-[#C5A25D] text-xl hover:text-white transition">مرکزی صفحہ</a>
        <a href="/meet-fahad" class="block text-gray-300 hover:text-[#C5A25D] text-xl transition">تعارف</a>
        <a href="/blueprint" class="block text-gray-300 hover:text-[#C5A25D] text-xl transition">منشور</a>
        <a href="/youth" class="block text-gray-300 hover:text-[#C5A25D] text-xl transition">نوجوانان</a>
        <a href="/media" class="block text-gray-300 hover:text-[#C5A25D] text-xl transition">میڈیا سینٹر</a>
        <div class="pt-4">
          <a href="/donate" class="inline-block bg-[#C5A25D] text-[#0A2F1D] px-10 py-3 rounded-md font-bold text-xl hover:bg-white transition shadow-lg">
            حصہ ڈالیں
          </a>
        </div>
      </div>
    </nav>

    <header class="relative w-full h-[60vh] flex items-center justify-center border-b border-white/10">
      <div class="absolute inset-0 bg-gradient-to-t from-[#0A2F1D] to-transparent z-10"></div>
      <div class="z-20 text-center px-4">
        <h1 class="text-4xl md:text-6xl text-[#C5A25D] font-urdu font-bold mb-4 leading-normal">
          استور کی ترقی، ہماری ذمہ داری
        </h1>
        <p class="text-xl md:text-2xl font-urdu max-w-3xl mx-auto leading-loose text-gray-300">
          ہم صرف وعدے نہیں کرتے، ہم عملی اقدامات پر یقین رکھتے ہیں۔ آئیں مل کر ایک خوشحال اور بااختیار معاشرے کی بنیاد رکھیں۔
        </p>
      </div>
    </header>

    <section class="max-w-7xl mx-auto px-6 py-16 mt-10 flex justify-start" dir="rtl">
      
      <div class="w-full lg:w-1/2 bg-[#062013] border border-[#C5A25D]/30 p-8 md:p-10 rounded-2xl shadow-2xl text-right relative">
        
        <div class="mb-8 border-b border-[#C5A25D]/20 pb-4">
          <span class="text-3xl block mb-2 opacity-80">🤝</span>
          <h2 class="text-xl md:text-2xl text-[#C5A25D] font-urdu font-bold mb-2 tracking-wide">مشورے / شکایات</h2>
          <p class="text-xs md:text-sm font-urdu text-gray-400 leading-relaxed">
            آپ کی رائے ہمارے لیے اہم ہے۔ اپنا پیغام درج کریں، یہ براہ راست قیادت تک پہنچے گا۔
          </p>
        </div>

        <form id="grievanceForm" class="space-y-6 font-urdu">
          
          <div>
            <label class="block text-[#C5A25D] text-xs font-semibold mb-2 opacity-90 tracking-wide">نام (اختیاری):</label>
            <input id="gName" type="text" placeholder="نام لکھیے..." style="height: 45px;" class="w-full bg-[#04180e] border border-[#C5A25D]/40 rounded-md px-4 font-urdu text-[#C5A25D] text-base focus:outline-none focus:border-[#C5A25D] focus:ring-1 focus:ring-[#C5A25D]/20 transition leading-normal placeholder-gray-600" />
          </div>

          <div>
            <label class="block text-[#C5A25D] text-xs font-semibold mb-2 opacity-90 tracking-wide">رابطہ نمبر:</label>
            <input id="gPhone" type="tel" required style="height: 45px;" class="w-full bg-[#04180e] border border-[#C5A25D]/40 rounded-md px-4 font-urdu text-[#C5A25D] text-base focus:outline-none focus:border-[#C5A25D] focus:ring-1 focus:ring-[#C5A25D]/20 transition text-right tracking-wider" dir="ltr" />
          </div>

          <div>
            <label class="block text-[#C5A25D] text-xs font-semibold mb-2 opacity-90 tracking-wide">علاقہ / حلقہ:</label>
            <select id="gHalqa" style="height: 45px;" class="w-full bg-[#04180e] border border-[#C5A25D]/40 rounded-md px-4 font-urdu text-[#C5A25D] text-base focus:outline-none focus:border-[#C5A25D] focus:ring-1 focus:ring-[#C5A25D]/20 transition leading-normal text-right">
              <option value="Not Selected" class="text-gray-500">انتخاب کریں...</option>
              <option value="Astore Khas">استور خاص</option>
              <option value="Shankar Garh">شنکر گڑھ</option>
              <option value="Gori Kot">گوری کوٹ</option>
              <option value="Mini Marg">منی مرگ</option>
              <option value="Other">دیگر علاقہ</option>
            </select>
          </div>

          <div>
            <label class="block text-[#C5A25D] text-xs font-semibold mb-2 opacity-90 tracking-wide">پیغام:</label>
            <textarea id="gMessage" rows="7" required placeholder="اپنے مشورے یا شکایات تفصیل سے تحریر کریں..." class="w-full bg-[#04180e] border border-[#C5A25D]/40 rounded-md px-4 py-4 font-urdu text-[#C5A25D] text-base focus:outline-none focus:border-[#C5A25D] focus:ring-1 focus:ring-[#C5A25D]/20 transition resize-none leading-relaxed tracking-wide placeholder-gray-600"></textarea>
          </div>

          <div class="pt-2">
            <button id="submitBtn" type="submit" style="height: 48px;" class="bg-[#C5A25D] text-[#0A2F1D] px-8 rounded-md font-bold text-lg hover:bg-white transition shadow-md w-full tracking-wide">
              جمع کروائیں
            </button>
          </div>

        </form>

      </div>
    </section>

    <script>
      import { supabase } from '../lib/supabase.js';

      const mobileBtn = document.getElementById('mobileMenuBtn');
      const mobileMenu = document.getElementById('mobileMenu');

      if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }

      const form = document.getElementById('grievanceForm');
      const submitBtn = document.getElementById('submitBtn');

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault(); 
          
          const originalBtnText = submitBtn.innerText;
          submitBtn.innerText = "براہ کرم انتظار کریں...";
          submitBtn.disabled = true;

          const voter_name = document.getElementById('gName').value;
          const phone = document.getElementById('gPhone').value;
          const halqa = document.getElementById('gHalqa').value;
          const message = document.getElementById('gMessage').value;

          const { data, error } = await supabase
            .from('grievances')
            .insert([
              { voter_name, phone, halqa, message }
            ]);

          if (error) {
            alert("کوئی مسئلہ پیش آیا ہے۔ براہ کرم دوبارہ کوشش کریں۔");
            submitBtn.innerText = originalBtnText;
            submitBtn.disabled = false;
          } else {
            form.innerHTML = `
              <div class="text-center py-16">
                <span class="text-5xl mb-4 block">✅</span>
                <h3 class="text-2xl text-[#C5A25D] font-urdu font-bold mb-3 leading-normal">شکریہ!</h3>
                <p class="text-white text-lg font-urdu leading-loose">آپ کا پیغام کامیابی سے موصول ہو گیا ہے اور قیادت کو ارسال کر دیا گیا ہے۔</p>
              </div>
            `;
          }
        });
      }
    </script>

  </body>
</html>