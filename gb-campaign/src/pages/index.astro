---
import '../styles/global.css';
---

<html lang="ur" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>میجر فہد حنیف خان | آفیشل کیمپین</title>
  </head>
  <body class="bg-[#0A2F1D] text-white">
    
    <nav class="border-b border-[#C5A25D]/30 bg-[#062013] px-6 py-4 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="text-[#C5A25D] font-bold text-2xl md:text-3xl font-urdu">
          میجر فہد حنیف خان
        </div>
        
        <div class="hidden lg:flex space-x-8 space-x-reverse font-urdu text-lg">
          <a href="/" class="text-[#C5A25D] border-b-2 border-[#C5A25D] pb-1">مرکزی صفحہ</a>
          <a href="/meet-fahad" class="hover:text-[#C5A25D] transition">تعارف</a>
          <a href="/blueprint" class="hover:text-[#C5A25D] transition">منشور</a>
          <a href="/youth" class="hover:text-[#C5A25D] transition">نوجوانان</a>
          <a href="/media" class="hover:text-[#C5A25D] transition">میڈیا سینٹر</a>
        </div>

        <div>
          <a href="/donate" class="bg-[#C5A25D] text-[#0A2F1D] px-6 py-2 rounded-md font-bold font-urdu text-lg hover:bg-white transition shadow-[0_0_15px_rgba(197,162,93,0.4)]">
            حصہ ڈالیں
          </a>
        </div>
      </div>
    </nav>

    <header class="relative w-full h-[60vh] flex items-center justify-center border-b border-white/10">
      <div class="absolute inset-0 bg-gradient-to-t from-[#0A2F1D] to-transparent z-10"></div>
      <div class="z-20 text-center px-4">
        <h1 class="text-4xl md:text-6xl text-[#C5A25D] font-urdu font-bold mb-4 leading-normal">
          استور کی ترقی، ہماری ذمہ داری
        </h1>
        <p class="text-xl md:text-2xl font-urdu max-w-3xl mx-auto leading-loose text-gray-300">
          ہم صرف وعدے نہیں کرتے، ہم عملی اقدامات پر یقین رکھتے ہیں۔ آئیں مل کر ایک خوشحال اور بااختیار معاشرے کی بنیاد رکھیں۔
        </p>
      </div>
    </header>
<section class="max-w-4xl mx-auto px-6 py-20 border-t border-[#C5A25D]/20 mt-20">
      <div class="bg-[#062013] border-2 border-[#C5A25D]/30 p-8 md:p-12 rounded-2xl shadow-2xl">
        
        <div class="text-center mb-10">
          <span class="text-4xl">🤝</span>
          <h2 class="text-3xl md:text-4xl text-[#C5A25D] font-urdu font-bold mt-4 mb-4">آپ ہم سے کیوں ناراض ہیں؟</h2>
          <p class="text-lg font-urdu leading-loose text-gray-300 max-w-2xl mx-auto">
            ہم استور کے ہر شہری کے تحفظات کو دور کرنے کے لیے پرعزم ہیں۔ اگر ہماری کسی پالیسی، فیصلے یا رویے سے آپ کو مایوسی ہوئی ہے، تو براہ کرم نیچے دیے گئے فارم کے ذریعے ہمیں آگاہ کریں۔ آپ کا پیغام براہ راست قیادت تک پہنچایا جائے گا اور اسے مکمل صیغہ راز میں رکھا جائے گا۔
          </p>
        </div>

        <form class="space-y-6 font-urdu text-right" dir="rtl">
          <div>
            <label class="block text-[#C5A25D] text-lg mb-2 font-bold">آپ کا نام (اختیاری):</label>
            <input type="text" placeholder="نام لکھیے..." class="w-full bg-[#0A2F1D] border border-[#C5A25D]/30 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#C5A25D] transition" />
          </div>

          <div>
            <label class="block text-[#C5A25D] text-lg mb-2 font-bold">رابطہ نمبر (تاکہ ہم آپ سے رابطہ کر سکیں):</label>
            <input type="tel" required placeholder="مثال: 03001234567" class="w-full bg-[#0A2F1D] border border-[#C5A25D]/30 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#C5A25D] transition text-left" dir="ltr" />
          </div>

          <div>
            <label class="block text-[#C5A25D] text-lg mb-2 font-bold">آپ کا علاقہ / یونین کونسل:</label>
            <select class="w-full bg-[#0A2F1D] border border-[#C5A25D]/30 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#C5A25D] transition">
              <option>انتخاب کریں...</option>
              <option>استور خاص</option>
              <option>شنکر گڑھ</option>
              <option>گوری کوٹ</option>
              <option>منی مرگ</option>
              <option>دیگر علاقہ</option>
            </select>
          </div>

          <div>
            <label class="block text-[#C5A25D] text-lg mb-2 font-bold">اپنی شکایت یا تجویز تفصیل سے لکھیے:</label>
            <textarea rows="5" required placeholder="اپنے تحفظات یہاں تحریر کریں..." class="w-full bg-[#0A2F1D] border border-[#C5A25D]/30 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#C5A25D] transition"></textarea>
          </div>

          <div class="text-center pt-4">
            <button type="submit" class="bg-[#C5A25D] text-[#0A2F1D] px-10 py-3 rounded-lg font-bold text-xl hover:bg-white transition shadow-lg w-full md:w-auto">
              شکایت درج کروائیں
            </button>
          </div>
        </form>

      </div>
    </section>
  </body>
</html>