      if(formOpp) {
        formOpp.onsubmit = async (e) => {
          e.preventDefault();
          const { error } = await supabase.from('opp_research').insert([{ candidate: document.getElementById('opCandidate').value, vulnerability: document.getElementById('opVuln').value, intel: document.getElementById('opIntel').value, weapon: document.getElementById('opWeapon').value, file_name: document.getElementById('opFile').value }]);
          if (error) alert("Error: " + error.message); else { alert("Intel Secured!"); formOpp.reset(); document.getElementById('formOpp').classList.add('hidden'); }
        };
      }

      const formNews = document.getElementById('addNewsForm');
      if(formNews) {
        formNews.onsubmit = async (e) => {
          e.preventDefault();
          const { error } = await supabase.from('news_broadcasts').insert([{ headline: document.getElementById('nwHeadline').value, status: document.getElementById('nwStatus').value, body: document.getElementById('nwBody').value }]);
          if (error) alert("Error: " + error.message); else { alert("Broadcast Queued!"); formNews.reset(); document.getElementById('formNews').classList.add('hidden'); }
        };
      }

      const formGoals = document.getElementById('addGoalsForm');
      if(formGoals) {
        formGoals.onsubmit = async (e) => {
          e.preventDefault();
          const { error } = await supabase.from('campaign_goals').insert([{ title: document.getElementById('glTitle').value, type: document.getElementById('glType').value, target: document.getElementById('glTarget').value, current: document.getElementById('glCurrent').value, strategy: document.getElementById('glStrategy').value }]);
          if (error) alert("Error: " + error.message); else { alert("Goal Tracked!"); formGoals.reset(); document.getElementById('formGoals').classList.add('hidden'); }
        };
      }

      const formPostal = document.getElementById('addPostalForm');
      if(formPostal) {
        formPostal.onsubmit = async (e) => {
          e.preventDefault();
          const { error } = await supabase.from('postal_ballots').insert([{ entity: document.getElementById('psEntity').value, count: document.getElementById('psCount').value, notes: document.getElementById('psNotes').value }]);
          if (error) alert("Error: " + error.message); else { alert("Ballots Logged!"); formPostal.reset(); document.getElementById('formPostal').classList.add('hidden'); }
        };
      }

      // DUMMY DATA
      const dummyData = {
        inbox: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('msg1')"><h4 class="truncate max-w-[200px] md:max-w-full">Gorikot Healthcare Petition</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag">URGENT</span><span id="icon_msg1" class="text-white font-bold">+</span></div></div><div id="msg1" class="hq-card-body hidden font-urdu text-right" dir="rtl">گوریکوٹ میں ادویات کی شدید کمی ہے، براہ کرم اس پر توجہ دیں۔</div></div>`,
        confirmed: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('cv1')"><h4>Rattoo Valley Bloc</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag text-white border-white">1,250 Voters</span><span id="icon_cv1" class="text-white font-bold">+</span></div></div><div id="cv1" class="hq-card-body hidden"><p class="text-sm text-white/80">Solid support from the local union. Key contact: Haji Mustafa.</p></div></div>`,
        swing: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('sv1')"><h4>Bunji Youth Council</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag">LEVERAGE: IT LAB</span><span id="icon_sv1" class="text-white font-bold">+</span></div></div><div id="sv1" class="hq-card-body hidden"><p class="text-sm text-white/80">Currently leaning towards opposition due to connectivity issues. Promising a fiber-optic node can flip 400 votes.</p></div></div>`,
        internal: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('ip1')"><h4>Operation Door-to-Door</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag text-red-500 border-red-500">IMPACT: HIGH</span><span id="icon_ip1" class="text-white font-bold">+</span></div></div><div id="ip1" class="hq-card-body hidden"><p class="text-sm text-white/80">Targeting 50 households per day in Dashkin sector. Handlers must emphasize digital job creation.</p></div></div>`,
        opp: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('intel1')"><h4 class="truncate max-w-[150px] md:max-w-full">Opponent A - Vulnerability</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag">WEAPON: CONTRACTS</span><span id="icon_intel1" class="text-white font-bold">+</span></div></div><div id="intel1" class="hq-card-body hidden"><p class="text-sm text-white/80">Found discrepancies in public road contracts for 2023. Ready for release in Week 4.</p></div></div>`,
        news: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('news1')"><h4 class="truncate max-w-[150px] md:max-w-full">Major Fahad Promises IT Rev</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag text-green-400 border-green-400">APPROVED</span><span id="icon_news1" class="text-white font-bold">+</span></div></div><div id="news1" class="hq-card-body hidden"><p class="text-sm text-white/80">Scheduled for broadcast on local GB networks tonight at 8:00 PM.</p></div></div>`,
        goals: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('goal1')"><h4 class="truncate max-w-[150px] md:max-w-full">Goal: 15,000 Verified Voters</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag text-blue-400 border-blue-400">62% DONE</span><span id="icon_goal1" class="text-white font-bold">+</span></div></div><div id="goal1" class="hq-card-body hidden"><p class="text-sm text-white/80">Target: 15k | Current: 9.3k. Strategy: Intensive focus on female voter registration in rural zones.</p></div></div>`,
        postal: `<div class="hq-card"><div class="hq-card-header" onclick="toggleAccordion('post1')"><h4>GB Education Dept</h4><div class="flex items-center gap-2 md:gap-4"><span class="status-tag text-white border-white">85 Ballots</span><span id="icon_post1" class="text-white font-bold">+</span></div></div><div id="post1" class="hq-card-body hidden"><p class="text-sm text-white/80">Secured through departmental focal person. Verified and logged for station dispatch.</p></div></div>`
      };

      document.getElementById('inboxContainer').innerHTML = dummyData.inbox;
      document.getElementById('voterTableBody').innerHTML = dummyData.confirmed;
      document.getElementById('swingContainer').innerHTML = dummyData.swing;
      document.getElementById('internalContainer').innerHTML = dummyData.internal;
      document.getElementById('oppContainer').innerHTML = dummyData.opp;
      document.getElementById('liveNewsFeed').innerHTML = dummyData.news;
      document.getElementById('goalsContainer').innerHTML = dummyData.goals;
      document.getElementById('postalContainer').innerHTML = dummyData.postal;

      // LOGIN EXECUTION
      loginForm.onsubmit = async (e) => {
        e.preventDefault();
        const { error } = await supabase.auth.signInWithPassword({ email: adminEmail.value, password: adminPassword.value });
        if (!error) { 
          loginScreen.classList.add('hidden'); 
          dashboardScreen.classList.remove('hidden'); 
          switchView('navInbox');
        } else { 
          alert("Unauthorized Command Key"); 
        }
      };
      
      document.getElementById('logoutBtn').onclick = () => location.reload();
    </script>
  </body>
</html>